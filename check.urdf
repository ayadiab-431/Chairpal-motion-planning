      </geometry>
    </collision>
    <gazebo reference="front_right_wheel">
      <mu1>5.0</mu1>
      <mu2>5.0</mu2>
      <self_collide>false</self_collide>
    </gazebo>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="bogie_front_arm_right"/>
    <child link="front_right_wheel"/>
    <origin rpy="0 -0.16 0" xyz="0.15 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="5"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>
  <!-- Middle Wheel -->
  <link name="middle_right_wheel">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0007166666666666668" ixy="0" ixz="0" iyy="0.0007166666666666668" iyz="0" izz="0.0012250000000000002"/>
    </inertial>
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.07"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.07"/>
      </geometry>
    </collision>
    <gazebo reference="middle_right_wheel">
      <mu1>5.0</mu1>
      <mu2>5.0</mu2>
      <self_collide>false</self_collide>
    </gazebo>
  </link>
  <joint name="middle_right_wheel_joint" type="continuous">
    <parent link="bogie_middle_arm_right"/>
    <child link="middle_right_wheel"/>
    <origin rpy="0 -1.38 0" xyz="0.15 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="5"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>
  <!-- Gazebo Plugins -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.07</wheel_radius>
      <topic>model/wheelchair/cmd_vel</topic>
      <odom_topic>model/wheelchair/odom</odom_topic>
      <tf_topic>model/wheelchair/tf</tf_topic>
      <!-- Speed limits to prevent runaway motion -->
      <max_linear_velocity>0.15</max_linear_velocity>
      <max_angular_velocity>0.4</max_angular_velocity>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <max_angular_acceleration>1.0</max_angular_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <joint_name>middle_left_wheel_joint</joint_name>
      <joint_name>middle_right_wheel_joint</joint_name>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>bogie_pivot_left_joint</joint_name>
      <joint_name>bogie_pivot_right_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
